# Fonzygrok Docker environment configuration.
# Copy to .env and customize as needed.

# --- Version & Build ---
FONZYGROK_VERSION=dev

# --- Networking ---
DOMAIN=tunnel.localhost
APEX_DOMAIN=fonzygrok.com
SSH_PORT=2222
HTTP_PORT=8080
HTTPS_PORT=443
ADMIN_PORT=9090
TLS_ENABLED=false

# --- TCP Tunnels ---
# Port range allocated for TCP tunnel listeners (MIN-MAX).
# Keep narrow to limit attack surface. Each active TCP tunnel uses one port.
TCP_PORT_RANGE=40000-40100

# --- Rate Limiting ---
# Default requests per second per tunnel. Set to 0 to disable.
RATE_LIMIT=100
# Default burst size (max requests allowed in a single burst).
RATE_BURST=200
