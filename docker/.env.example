# Fonzygrok Docker Configuration
# Copy this to .env and modify as needed.

# Domain for tunnel routing. Tunnels get subdomains: <name>.<domain>
# Production: fonzygrok.com → my-app.fonzygrok.com
DOMAIN=localhost

# Apex domain for dashboard (leave empty — defaults to same as DOMAIN)
APEX_DOMAIN=

# PostgreSQL credentials
POSTGRES_USER=fonzygrok
POSTGRES_PASSWORD=fonzygrok
POSTGRES_DB=fonzygrok

# Enable TLS (auto-TLS via Let's Encrypt)
TLS_ENABLED=false

# Port configuration
SSH_PORT=2222
HTTPS_PORT=443

# TCP tunnel port range (each TCP tunnel gets one port from this range)
TCP_PORT_RANGE=40000-40100

# Rate limiting (requests per second per tunnel, 0 = disabled)
RATE_LIMIT=100
RATE_BURST=200
