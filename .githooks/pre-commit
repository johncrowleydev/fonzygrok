#!/usr/bin/env bash
# pre-commit hook: Block commits containing private keys, credentials, or database files.
#
# Install: git config core.hooksPath .githooks
# Or:      cp .githooks/pre-commit .git/hooks/pre-commit
#
# This hook exists because fonzygrok.pem and tmp/data/ (containing the SSH host key,
# production database with password hashes and tokens) were committed to a public
# GitHub repo. See DEF-005 for the full incident report.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

BLOCKED=0

# в”Ђв”Ђ Check staged file patterns в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# These patterns should NEVER appear in a commit.

DANGEROUS_PATTERNS=(
    '\.pem$'
    '\.key$'
    '\.p12$'
    '\.pfx$'
    '\.jks$'
    '\.keystore$'
    'id_rsa'
    'id_ed25519'
    'id_ecdsa'
    'host_key'
    '\.db$'
    '\.db-shm$'
    '\.db-wal$'
    '\.db-journal$'
    '\.sqlite3?$'
    '\.env$'
    '\.env\.local$'
    '\.env\.production$'
    '\.secret$'
    'jwt_secret'
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [ -n "$STAGED_FILES" ]; then
    for pattern in "${DANGEROUS_PATTERNS[@]}"; do
        MATCHES=$(echo "$STAGED_FILES" | grep -iE "$pattern" || true)
        if [ -n "$MATCHES" ]; then
            echo -e "${RED}рџљ« BLOCKED: Staged file matches dangerous pattern '${pattern}':${NC}"
            echo "$MATCHES" | while read -r f; do echo -e "   ${YELLOW}$f${NC}"; done
            BLOCKED=1
        fi
    done
fi

# в”Ђв”Ђ Check staged file contents for private key headers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Even if the filename doesn't match, the content might contain a key.

KEY_HEADERS=(
    'BEGIN RSA PRIVATE KEY'
    'BEGIN OPENSSH PRIVATE KEY'
    'BEGIN EC PRIVATE KEY'
    'BEGIN DSA PRIVATE KEY'
    'BEGIN PRIVATE KEY'
    'BEGIN ENCRYPTED PRIVATE KEY'
)

if [ -n "$STAGED_FILES" ]; then
    for header in "${KEY_HEADERS[@]}"; do
        for file in $STAGED_FILES; do
            # Skip hook scripts and config files (they contain key header strings as patterns)
            case "$file" in .githooks/*|.gitignore) continue ;; esac
            if [ -f "$file" ] && grep -q "$header" "$file" 2>/dev/null; then
                echo -e "${RED}рџљ« BLOCKED: File '$file' contains private key header '${header}'${NC}"
                BLOCKED=1
            fi
        done
    done
fi

# в”Ђв”Ђ Check for tmp/ directory в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

TMP_FILES=$(echo "$STAGED_FILES" | grep -E '^tmp/' || true)
if [ -n "$TMP_FILES" ]; then
    echo -e "${RED}рџљ« BLOCKED: Files in tmp/ directory should never be committed:${NC}"
    echo "$TMP_FILES" | while read -r f; do echo -e "   ${YELLOW}$f${NC}"; done
    BLOCKED=1
fi

# в”Ђв”Ђ Verdict в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

if [ "$BLOCKED" -eq 1 ]; then
    echo ""
    echo -e "${RED}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${NC}"
    echo -e "${RED}  COMMIT BLOCKED: Potential credentials or secrets detected.   ${NC}"
    echo -e "${RED}  If this is intentional, use: git commit --no-verify          ${NC}"
    echo -e "${RED}  But think VERY carefully before bypassing this check.        ${NC}"
    echo -e "${RED}в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ${NC}"
    exit 1
fi

exit 0
