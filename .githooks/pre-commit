#!/usr/bin/env bash
# pre-commit hook: Block commits containing private keys, credentials, or database files.
#
# Install: git config core.hooksPath .githooks
# Or:      cp .githooks/pre-commit .git/hooks/pre-commit
#
# This hook exists because private keys and the production database were
# committed to a public GitHub repo. See DEF-005 for the full incident report.

set -e

BLOCKED=0

# ── Get staged files (added, copied, modified — not deleted) ──────────────────
STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)" || true

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# ── Check staged file patterns ────────────────────────────────────────────────

check_pattern() {
    local pattern="$1"
    local matches
    matches="$(echo "$STAGED_FILES" | grep -iE "$pattern" || true)"
    if [ -n "$matches" ]; then
        echo "BLOCKED: Staged file matches dangerous pattern '$pattern':"
        echo "$matches" | sed 's/^/   /'
        BLOCKED=1
    fi
}

check_pattern '\.pem$'
check_pattern '\.key$'
check_pattern '\.p12$'
check_pattern '\.pfx$'
check_pattern '\.jks$'
check_pattern '\.keystore$'
check_pattern 'id_rsa'
check_pattern 'id_ed25519'
check_pattern 'id_ecdsa'
check_pattern 'host_key'
check_pattern '\.db$'
check_pattern '\.db-shm$'
check_pattern '\.db-wal$'
check_pattern '\.db-journal$'
check_pattern '\.sqlite3?$'
check_pattern '^\.env$'
check_pattern '\.env\.local$'
check_pattern '\.env\.production$'
check_pattern '\.secret$'
check_pattern 'jwt_secret'

# ── Check staged file contents for private key headers ────────────────────────

while IFS= read -r file; do
    # Skip hook scripts and config files (they reference key headers as patterns)
    case "$file" in .githooks/*|.gitignore) continue ;; esac

    if [ -f "$file" ]; then
        if grep -qE 'BEGIN (RSA |OPENSSH |EC |DSA |ENCRYPTED )?PRIVATE KEY' "$file" 2>/dev/null; then
            echo "BLOCKED: File '$file' contains a private key header"
            BLOCKED=1
        fi
    fi
done <<< "$STAGED_FILES"

# ── Check for tmp/ directory ──────────────────────────────────────────────────

tmp_files="$(echo "$STAGED_FILES" | grep -E '^tmp/' || true)"
if [ -n "$tmp_files" ]; then
    echo "BLOCKED: Files in tmp/ directory should never be committed:"
    echo "$tmp_files" | sed 's/^/   /'
    BLOCKED=1
fi

# ── Verdict ───────────────────────────────────────────────────────────────────

if [ "$BLOCKED" -eq 1 ]; then
    echo ""
    echo "================================================================="
    echo "  COMMIT BLOCKED: Potential credentials or secrets detected."
    echo "  If this is intentional, use: git commit --no-verify"
    echo "  But think VERY carefully before bypassing this check."
    echo "================================================================="
    exit 1
fi

exit 0
